{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}