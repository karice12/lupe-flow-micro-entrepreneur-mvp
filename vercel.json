{
  "version": 2,
  "buildCommand": "npm run build",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "api/index.py" },
    { "source": "/webhook/:path*", "destination": "api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": { "api/*.py": { "maxDuration": 10 } },
  "trailingSlash": false
}
