{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install && pip install -r requirements.txt",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "api/index.py" },
    { "source": "/webhook/:path*", "destination": "api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}