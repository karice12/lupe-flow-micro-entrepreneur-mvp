{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/index.py": {
      "runtime": "python3.12"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "api/index.py" },
    { "source": "/webhook/:path*", "destination": "api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
